# Firebase — use DIFFERENT projects for Development vs Production
# so test orders never land in the live kitchen database.
#
# Local / Vercel Preview / GitHub CI (FIREBASE_DEV_*)  → chatkara-dev
# Vercel Production                                    → La Gardenia (prod)
#
# Nightly: smoke hits the live Production URL (UI only).
#          Order-writing tests use a local server + FIREBASE_DEV_*.
#
# Optional explicit override (defaults from VERCEL_ENV):
CHATKARA_ENV=development

# --- Development Firebase (local .env.local should use these) ---
FIREBASE_API_KEY=your_dev_api_key_here
FIREBASE_AUTH_DOMAIN=chatkara-dev.firebaseapp.com
FIREBASE_PROJECT_ID=chatkara-dev
FIREBASE_STORAGE_BUCKET=chatkara-dev.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_dev_messaging_sender_id
FIREBASE_APP_ID=your_dev_app_id

# Admin kitchen / analytics UI password (required — no default)
ADMIN_PASSWORD=change-me

# Optional: separate HMAC secret for admin cookies (defaults to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET=another-long-random-string

# Shared secret for CI/integration tests.
# Requests with header x-chatkara-test-key: <secret> create isTest=true orders
# in the Dev database (left in place — no auto-delete).
E2E_TEST_SECRET=change-me-long-random-string

# Telegram kitchen alerts (optional)
# 1. Message @BotFather → /newbot → copy token
# 2. DM the bot /start (or add to a group) and copy chat.id from getUpdates
# 3. For buttons, setWebhook on a public host (not localhost).
#    If Preview has Vercel Authentication, append:
#      ?x-vercel-protection-bypass=$VERCEL_AUTOMATION_BYPASS_SECRET
#    curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook" \
#      --data-urlencode "url=https://YOUR_DOMAIN/api/telegram/webhook?x-vercel-protection-bypass=..." \
#      -d "secret_token=$TELEGRAM_WEBHOOK_SECRET" \
#      -d 'allowed_updates=["callback_query"]'
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Random string (e.g. openssl rand -hex 24) — must match setWebhook secret_token
TELEGRAM_WEBHOOK_SECRET=

# --- GitHub Actions (repo secrets) ---
# FIREBASE_DEV_*     → chatkara-dev (PR CI + nightly write suite)
# FIREBASE_*         → optional; keep as Production if already set (not used for writes)
# ADMIN_PASSWORD, E2E_TEST_SECRET
# Optional variable: PRODUCTION_URL=https://chatkara.lagardenia.in
